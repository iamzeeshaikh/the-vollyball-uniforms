---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import { locationStates } from '../../data/locations';

const totalCities = locationStates.reduce((n, s) => n + s.cities.length, 0);
const schema = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'USA Volleyball Uniform Locations — The Volleyball Uniforms',
  itemListElement: locationStates.map((s, i) => ({ '@type': 'ListItem', position: i + 1, name: `Custom Volleyball Uniforms in ${s.name}`, url: `https://thevolleyballuniforms.com/locations/${s.slug}/` })),
};
---
<BaseLayout
  title="Custom Volleyball Uniforms Across the USA | State & City Locations | The Volleyball Uniforms"
  description="Custom volleyball uniforms and team kits for club, high school, college, and beach teams across the USA. Find your state and city, or get a free quote."
  canonical="https://thevolleyballuniforms.com/locations/"
  schema={schema}
>
  <div class="bg-navy-950"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><Breadcrumbs items={[{ label: 'Locations' }]} /></div></div>

  <section class="bg-navy-950 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-400">USA Volleyball</span>
      <h1 class="mt-3 max-w-3xl text-4xl sm:text-5xl font-extrabold leading-tight">Custom Volleyball Uniforms Across the USA</h1>
      <p class="mt-4 max-w-2xl text-lg text-navy-200 leading-relaxed">
        From the beach courts of California to the powerhouse clubs of Chicago and Dallas, we build custom sublimated volleyball uniforms and team kits for programs in every corner of the country. Find your state and city, or <a href="/request-a-quote/" class="text-gold-400 font-semibold underline">get a free team quote</a>.
      </p>
    </div>
  </section>

  {locationStates.map((s) => (
    <section class="py-12 border-b border-gray-200 last:border-0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between gap-4">
          <h2 class="text-2xl font-extrabold text-navy-950">{s.name}</h2>
          <a href={`/locations/${s.slug}/`} class="text-sm font-semibold text-electric-600 hover:text-electric-700">All {s.name} →</a>
        </div>
        <p class="mt-1 text-sm text-gray-500">{s.stat}.</p>
        <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {s.cities.map((c) => (
            <a href={`/locations/${s.slug}/${c.slug}/`} class="rounded-2xl border border-gray-200 bg-white p-5 hover:shadow-lg transition-shadow">
              <h3 class="font-bold text-navy-950">{c.name}, {s.abbr}</h3>
              <p class="mt-1 text-sm text-gray-500">{c.stat}.</p>
              <span class="mt-2 inline-block text-sm font-semibold text-electric-600">Volleyball uniforms in {c.name} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <CTASection title="Don't See Your City?" subtitle="We outfit volleyball teams in every corner of the country, not just the cities listed here. Tell us your team and colors for a free quote." />
</BaseLayout>
