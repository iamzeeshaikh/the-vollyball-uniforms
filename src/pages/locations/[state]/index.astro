---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CTASection from '../../../components/CTASection.astro';
import QuoteForm from '../../../components/QuoteForm.astro';
import { products } from '../../../data/products';
import { locationStates, getLocationState, vbLinkTargets, vbAnchor, vbPick } from '../../../data/locations';

export function getStaticPaths() {
  return locationStates.map((s) => ({ params: { state: s.slug } }));
}

const { state: stateSlug } = Astro.params;
const state = getLocationState(stateSlug!);
if (!state) return Astro.redirect('/locations/');

const getP = (s: string) => products.find((p) => p.slug === s);
const basePath = `/locations/${state.slug}/`;
const styleGrid = vbLinkTargets('style-' + state.slug, 4).map(getP).filter(Boolean) as NonNullable<ReturnType<typeof getP>>[];
const lt = vbLinkTargets(state.slug, 2);
const L = lt.map((s, i) => ({ href: `/${s}/`, text: vbAnchor(s, state.slug, i) }));
const sceneLine = vbPick([
  { pre: `Across the state, teams reach for our `, post: ` to look sharp from the first serve.` },
  { pre: `From club ball to varsity, ${state.name} programs lean on our `, post: `.` },
  { pre: `The most-ordered pick across ${state.name} tends to be our `, post: `, printed to spec.` },
], state.slug, 0);
const whoLine = vbPick([
  { pre: `We outfit the full range of ${state.name} volleyball — many teams start with our `, post: ` and build from there.` },
  { pre: `From a first club roster to a full varsity program, ${state.name} teams order from us, including our `, post: `.` },
  { pre: `Whatever your level, there's a fit — our `, post: ` included.` },
], state.slug, 1);

const faqs = [
  { question: `Do you make custom volleyball uniforms across ${state.name}?`, answer: `Yes. We build and ship custom volleyball uniforms to teams across ${state.name}, including ${state.cities.map((c) => c.name).join(', ')} and surrounding areas. Send your roster and colors for a team quote.` },
  { question: `What is the minimum order?`, answer: `We build full-team orders and keep minimums practical for ${state.name} programs, from a club roster to a varsity squad. Share your player count for a tailored quote.` },
  { question: `Can you match our exact club or school colors?`, answer: `Yes. Every uniform is fully dye-sublimated to your exact colors, logo, and design, so your ${state.name} team's identity is reproduced precisely, every reorder.` },
  { question: `Are your uniforms sublimated or screen printed?`, answer: `We specialize in full dye-sublimation, where the design is infused into the fabric so names, numbers, and logos never crack, peel, or fade.` },
  { question: `Are your high school uniforms NFHS compliant?`, answer: `Yes. Our high school volleyball uniforms follow NFHS standards by default, including number sizing and placement and libero color-contrast rules.` },
  { question: `Do you offer full team kits, not just jerseys?`, answer: `Yes. We outfit ${state.name} teams head to toe — jerseys, shorts or spandex, practice gear, warm-ups, and more — for a unified program look.` },
  { question: `Can you print custom names and numbers?`, answer: `Absolutely. Names, numbers, captain designations, and libero jerseys are all part of your team order.` },
  { question: `How fast can you deliver before our season?`, answer: `We plan production around your season and tournament dates. Order early for the best turnaround, and tell us any ${state.name} qualifier deadlines up front.` },
  { question: `Do you send a design proof before production?`, answer: `Always. You'll approve a design mockup before anything is produced, so your ${state.name} uniforms come out exactly as intended.` },
  { question: `How do we get a quote for our ${state.name} team?`, answer: `Send your team name, colors, roster count, and design ideas through our quote form and we'll return pricing, fabric options, and a timeline.` },
];

const collectionSchema = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: `Custom Volleyball Uniforms in ${state.name}`,
  url: `https://thevolleyballuniforms.com${basePath}`,
  description: state.metaDescription,
  mainEntity: { '@type': 'ItemList', itemListElement: state.cities.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: `Custom Volleyball Uniforms in ${c.name}`, url: `https://thevolleyballuniforms.com/locations/${state.slug}/${c.slug}/` })) },
};
---
<BaseLayout title={state.metaTitle} description={state.metaDescription} canonical={`https://thevolleyballuniforms.com${basePath}`} schema={collectionSchema}>
  <div class="bg-navy-950"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><Breadcrumbs items={[{ label: 'Locations', href: '/locations/' }, { label: state.name }]} /></div></div>

  <section class="bg-navy-950 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-[1.4fr_1fr] gap-10 items-center">
      <div>
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-400">USA · {state.abbr}</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold leading-tight">{state.h1}</h1>
        <p class="mt-4 max-w-xl text-lg text-navy-200 leading-relaxed">{state.intro}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/request-a-quote/" class="btn-primary py-3 px-6 text-sm">Get a Team Quote</a>
          <a href="/locations/" class="inline-flex items-center rounded-lg border border-white/25 px-6 py-3 text-sm font-semibold text-white hover:border-gold-400 transition-colors">All USA Locations</a>
        </div>
      </div>
      <div class="rounded-2xl border border-white/12 bg-white/5 p-6">
        <p class="border-b border-white/12 pb-3 font-extrabold text-gold-400">🏐 {state.stat}</p>
        <ul class="mt-3 space-y-2.5 text-sm text-navy-100">{state.cities.map((c) => <li class="flex items-start gap-2"><span class="text-gold-400">🏐</span>{c.name}, {state.abbr}</li>)}</ul>
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-[1.6fr_1fr] gap-10 items-start">
      <div>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-navy-950">{state.sceneHeading}</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">{state.marketScene}</p>
        <p class="mt-4 text-gray-600 leading-relaxed">{sceneLine.pre}<a href={L[0].href} class="text-electric-600 font-semibold underline">{L[0].text}</a>{sceneLine.post}</p>
      </div>
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-bold text-navy-950">Get a {state.name} Team Quote</h3>
        <p class="mt-2 text-sm text-gray-600">Send your team name, colors, and roster for a fast, free quote.</p>
        <QuoteForm productName={`Volleyball Uniforms — ${state.name}`} formId="state-quote" />
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-electric-600">Who We Outfit</span>
      <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold text-navy-950">{state.name} Volleyball We Serve</h2>
      <p class="mt-4 text-gray-600 leading-relaxed">{whoLine.pre}<a href={L[1].href} class="text-electric-600 font-semibold underline">{L[1].text}</a>{whoLine.post}</p>
      <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">{state.industries.map((i) => <li class="flex items-start gap-2 text-navy-900"><span class="text-electric-600">✓</span>{i}</li>)}</ul>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-electric-600">Cities</span>
      <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold text-navy-950">Custom Volleyball Uniforms by City in {state.name}</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {state.cities.map((c) => (
          <a href={`/locations/${state.slug}/${c.slug}/`} class="rounded-2xl border border-gray-200 bg-white p-5 hover:shadow-lg transition-shadow">
            <h3 class="font-bold text-navy-950">{c.name}, {state.abbr}</h3>
            <p class="mt-1 text-sm text-gray-500">{c.intro.slice(0, 100)}…</p>
            <span class="mt-2 inline-block text-sm font-semibold text-electric-600">Volleyball uniforms in {c.name} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-electric-600">Uniform Styles</span>
      <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold text-navy-950">Popular Styles in {state.name}</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {styleGrid.map((p) => (
          <a href={`/${p.slug}/`} class="group overflow-hidden rounded-2xl border border-gray-200 bg-white hover:shadow-lg transition-shadow">
            <div class="aspect-[4/3] overflow-hidden bg-gray-100"><img src={p.images[0]} alt={`${p.name} for ${state.name} teams`} loading="lazy" width="400" height="300" class="h-full w-full object-cover" /></div>
            <div class="p-4"><h3 class="font-bold text-navy-950">{p.name}</h3><p class="mt-1 text-sm text-gray-500">{p.shortDescription.slice(0, 78)}…</p><span class="mt-2 inline-block text-sm font-semibold text-electric-600">View {p.name} →</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <FAQSection faqs={faqs} title={`${state.name} Volleyball Uniforms — FAQs`} />
    </div>
  </section>

  <CTASection title={`Outfit Your ${state.name} Team`} subtitle={`Send your team name, colors, and roster for a free design mockup and quote — anywhere in ${state.name}.`} />
</BaseLayout>
