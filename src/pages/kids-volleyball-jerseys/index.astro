---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const product = products.find(p => p.slug === 'kids-volleyball-jerseys')!;
const related = products.filter(p => ['youth-volleyball-jerseys', 'youth-volleyball-uniforms', 'volleyball-practice-jerseys'].includes(p.slug));

const specs = [
  { label: 'Primary Material', value: '100% Lightweight Performance Polyester' },
  { label: 'Fabric Weight', value: '3.8 oz/yd² breathable mesh-back' },
  { label: 'Fit', value: 'Youth athletic cut with relaxed movement allowance' },
  { label: 'Sizes Available', value: 'YXS, YS, YM, YL, YXL' },
  { label: 'Customization', value: 'Full dye-sublimation: team colors, numbers, names, logos' },
  { label: 'Neckline', value: 'Tagless crew neck for comfort against young skin' },
  { label: 'Seam Construction', value: 'Flatlock seams — no chafing or irritation' },
  { label: 'Care', value: 'Machine wash cool, tumble dry low' },
  { label: 'Minimum Order', value: 'No minimum — single jerseys accepted' },
];

const faqs = [
  {
    question: 'What youth sizes are available for kids volleyball jerseys?',
    answer: 'We offer five youth sizes: YXS (ages 4–6), YS (ages 6–8), YM (ages 8–10), YL (ages 10–12), and YXL (ages 12–14). These are general age guides — we recommend using our youth measurement chart to determine the correct fit based on each child\'s chest circumference and body length rather than relying on age alone.',
  },
  {
    question: 'What fabric do you use for kids jerseys, and is it safe for sensitive skin?',
    answer: 'Kids volleyball jerseys are produced on a 3.8 oz lightweight performance polyester with a tagless neck label and flatlock seams. The lighter weight increases airflow during active play, and the tagless construction eliminates the irritation that traditional labels cause young players. The fabric is free of formaldehyde-based finishing chemicals and meets OEKO-TEX Standard 100 requirements.',
  },
  {
    question: 'My youngest player is 5 years old — do you have a jersey small enough?',
    answer: 'Yes. Our YXS size is designed for children approximately 4–6 years old with chest measurements of 22–24 inches. If you have a child near the lower end of that range, we can review measurements directly and advise on fit. We\'d rather help you find the right size than ship a jersey that doesn\'t fit a young player.',
  },
  {
    question: 'We have 60 kids in our youth league — can you handle that size order?',
    answer: 'Absolutely. Large youth league orders are among our most common requests, particularly for recreational programs that outfit an entire age group at once. We manage large orders with a coordinator-assigned account manager who tracks every size, name, and number in a shared roster document. We provide sorted, labeled packaging by team or age group for easy distribution on pickup day.',
  },
  {
    question: 'What design options work best for a kids team aesthetic?',
    answer: 'Kids teams often benefit from bright, energetic color schemes that generate excitement among young players and parents in the stands. We offer the full range of sublimation design options including bold color blocks, gradient effects, and mascot illustrations. Many youth leagues also choose to put player first names (rather than surnames) on the back, which helps coaches and parents identify players quickly during hectic practices.',
  },
  {
    question: 'How should parents care for sublimated kids jerseys after the season?',
    answer: 'Sublimated jerseys are among the most wash-friendly athletic garments available. Machine wash in cool water with a mild detergent and tumble dry on low. Avoid bleach, fabric softeners, and high dryer heat — all of which can stress the polyester fibers over time. The sublimated design itself is permanent and will not fade regardless of washing frequency, making these jerseys a good keepsake even after a child outgrows them.',
  },
  {
    question: 'Can we rush order kids jerseys for a tournament that\'s three weeks away?',
    answer: 'Rush production (7–10 business days after artwork approval) is available and can accommodate a 3-week timeline assuming your artwork and roster are ready to submit immediately. We recommend contacting us as soon as you know a tournament deadline is approaching — waiting even one or two days can make the difference between standard and rush production. Rush orders carry an additional production fee.',
  },
  {
    question: 'Our kids range in age from 7 to 13 — how do we get the right fit for everyone?',
    answer: 'Send all players home with our printable youth measurement guide, which asks parents to measure chest circumference and torso length. Collect the completed measurements (not just clothing size labels from other garments) and enter them into our roster template. Our sizing algorithm then maps each measurement to the correct jersey size. We flag any borderline measurements for discussion before production to avoid fit issues.',
  },  { question: 'Are kids volleyball jersey fabrics safe for children with sensitive skin?', answer: 'Yes. Our youth jersey fabrics are free from formaldehyde, azo dyes, and other substances restricted in children\'s apparel. The tagless label construction eliminates the most common source of skin irritation in youth athletic wear. The performance polyester is smooth against the skin and does not cause the chafing or irritation that heavier woven fabrics produce during active play.' },
  { question: 'What is the smallest jersey size you produce for youth players?', answer: 'Our smallest size is YXS, designed for players approximately ages 4–6 with a chest circumference of 22–24 inches. For players below this size range, we can produce jerseys to custom body measurements — contact us with the player\'s exact chest, shoulder width, and body length and we will advise on the best approach. We do not charge a design fee for custom-dimension youth jerseys.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Kids Volleyball Jerseys',
  description: 'Custom volleyball jerseys for kids in youth sizes YXS through YXL. Lightweight, breathable, and fully customizable for young teams.',
  brand: { '@type': 'Brand', name: 'The Volleyball Uniforms' },
  url: `https://thevolleyballuniforms.com/${product.slug}/`,
  image: product.images.map(img => `https://thevolleyballuniforms.com${img}`),
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    price: '14.00',
    priceValidUntil: '2027-12-31',
    url: `https://thevolleyballuniforms.com/${product.slug}/`,
    seller: { '@type': 'Organization', name: 'The Volleyball Uniforms', url: 'https://thevolleyballuniforms.com' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '63' , bestRating: '5', worstRating: '1' },
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Volleyball Jerseys', href: '/volleyball-jerseys/' },
  { label: 'Kids Volleyball Jerseys' },
];
import InlineQuoteSection from '../../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Kids Volleyball Jerseys — Youth Sizes & Custom Designs | The Volleyball Uniforms"
  description="Custom volleyball jerseys for kids in youth sizes YXS–YXL. Lightweight, breathable, fully customizable with your team colors & numbers. No minimum. Get a quote."
  schema={schema}
  canonical="https://thevolleyballuniforms.com/kids-volleyball-jerseys/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <ProductGallery images={product.images} productName={product.name} />
        <div>
          <div class="text-sm text-electric-600 font-semibold mb-2">Volleyball Jerseys</div>
          <h1 class="text-4xl font-extrabold text-navy-950 mb-4 leading-tight">Kids Volleyball Jerseys</h1>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">{[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <span class="text-sm text-gray-500">4.8 / 5 (63 reviews)</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-6">Young athletes deserve jerseys that fit well, feel great, and hold up through an entire season of gym play. Our kids volleyball jerseys are cut specifically for youth bodies — lighter fabric, tagless construction, flatlock seams — and fully customizable with your league's colors, team name, and player numbers. No minimum order, no complexity.</p>
          <div class="space-y-3 mb-8">
            {['Youth sizes YXS through YXL', 'Lightweight 3.8 oz breathable fabric', 'Tagless neck for sensitive skin', 'Flatlock seams prevent chafing', 'Full sublimation — names, numbers, logos', 'No minimum order quantity'].map(f => (
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-electric-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {f}
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary w-full justify-center mb-4">Request a Quote</a>
          <a href="/size-guide/" class="btn-outline w-full justify-center text-sm">View Size Guide</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 prose-custom">
      <h2>Designed for Young Athletes, Not Just Scaled Down</h2>
      <p>Kids volleyball jerseys shouldn't be adult jerseys made in smaller sizes. Young players move differently — they're learning arm swings, working on serve receive, and spending time on the floor during drills. Our youth cut is engineered with wider armhole openings and a slightly longer hem to stay tucked during active movement, while the 3.8 oz lightweight fabric keeps things cool in school gyms and recreation center courts.</p>

      <h2>Youth-Specific Fit and Construction</h2>
      <p>Children's skin is more sensitive to rough fabrics, tight tags, and raised seams than adult players. Every kids volleyball jersey we produce includes a tagless neck label printed directly onto the inner collar and flatlock seaming throughout the body and sleeves. Flatlock seams lie completely flat against the skin rather than protruding inward, eliminating the chafing and irritation that standard overlocked seams cause during extended play sessions.</p>
      <h3>Sizing from Youngest to Oldest in a Youth Program</h3>
      <p>A typical youth recreational program spans ages 6 through 14, which means a single order may include sizes ranging from YXS to YXL. We handle mixed-size youth orders routinely — each jersey is individually produced per the roster, and we sort and package completed orders by team or age group. For competitive travel club programs that bridge youth and adult sizing, see our <a href="/youth-volleyball-jerseys/">youth volleyball jerseys</a> page for sizing options that extend into adult small.</p>

      <h2>Material and Fabric Details</h2>
      <p>Kids volleyball jerseys use a 3.8 oz performance polyester with a mesh-back construction. The mesh panels across the shoulder blades and upper back provide maximum airflow for players who tend to run hot during indoor training sessions. The polyester base accepts full dye-sublimation printing with the same vibrancy and permanence as our adult jersey lineup. Bright team colors, bold numbers, and custom logos look vivid on game day and remain vivid after an entire season of regular washing.</p>

      <h2>Customization Options</h2>
      <p>Youth leagues often have the most creative design opportunities — kids teams embrace bold colors, mascot characters, and energetic graphic styles that adult teams rarely choose. We offer the full sublimation design library for kids jerseys: solid colors, color-blocked panels, gradient effects, mascot artwork, and sponsor logos. Player first names on the back are especially popular for recreational leagues where young players are just getting to know their teammates. Start your design process through our <a href="/request-a-quote/">quote form</a>.</p>

      <h2>Sizing Information</h2>
      <p>Youth sizing spans YXS through YXL, corresponding roughly to ages 4–14. We provide a printable measurement guide for parents to use at home, asking for chest circumference and body length. Using measurements rather than listed ages prevents the common problem of borderline-size children receiving jerseys that are too tight or too long. Visit our <a href="/size-guide/">size guide</a> for the complete youth measurement chart and fit guidance for each size.</p>

      <h2>Bulk Order Benefits</h2>
      <p>Youth leagues that order jerseys for an entire division or multiple teams simultaneously unlock per-unit pricing that makes fully sublimated jerseys competitive with screen-printed alternatives. Because we have no minimum order, small teams or single players can also order at standard pricing. We handle large league orders — 50 to 200 jerseys — with dedicated account management and organized delivery packaging.</p>

      <h2>Use Cases</h2>
      <ul>
        <li>Recreational youth volleyball leagues outfitting multiple teams in a single season order</li>
        <li>YMCA and community center programs providing matching jerseys for 6–14 year old participants</li>
        <li>Elementary school PE programs ordering jerseys for intramural volleyball competitions</li>
        <li>Parents ordering a single personalized jersey as a gift for a young player joining a team</li>
        <li>Travel club programs bridging youth and adult sizing with a consistent uniform design</li>
      </ul>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <SpecsTable specs={specs} title="Kids Volleyball Jerseys Specifications" />
    </div>
  </section>

  <FAQSection faqs={faqs} title="Kids Volleyball Jerseys FAQs" />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-navy-950 mb-8">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map(p => <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />)}
      </div>
    </div>
  </section>

  <InlineQuoteSection productName={product.name} />


  <CTASection title="Let Every Young Player Wear Their Name" subtitle="No minimums, youth sizing, free mockup — get your kids league set up today." />
</BaseLayout>
