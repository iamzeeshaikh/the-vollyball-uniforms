---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const product = products.find(p => p.slug === 'men-volleyball-jerseys')!;
const related = products.filter(p => ['men-volleyball-uniforms', 'sublimated-volleyball-jerseys', 'volleyball-compression-shirts'].includes(p.slug));

const specs = [
  { label: 'Primary Material', value: '100% Performance Polyester' },
  { label: 'Fabric Weight', value: '4.5 oz/yd² moisture-wicking interlock' },
  { label: 'Fit Options', value: 'Athletic (tapered) or relaxed (straight)' },
  { label: 'Sizes Available', value: 'S – 4XL (men\'s cut)' },
  { label: 'Customization', value: 'Full dye-sublimation: colors, logos, names, numbers' },
  { label: 'Armhole Style', value: 'Deep-cut athletic armhole for range of motion' },
  { label: 'Shoulder Width', value: 'Men\'s-specific wider shoulder construction' },
  { label: 'Body Length', value: 'Extended torso length vs. women\'s cut' },
  { label: 'Care', value: 'Machine wash cool, tumble dry low' },
];

const faqs = [
  {
    question: 'What cut options are available specifically for men\'s volleyball jerseys?',
    answer: 'We offer two cuts for men\'s jerseys: athletic fit (tapered through the body with a trim silhouette) and relaxed fit (straight-cut torso for players who prefer more room during lateral movement). Athletic fit is the standard for competitive programs, while relaxed fit is popular with adult recreational leagues. Both cuts feature wider shoulder construction and extended torso length specific to the men\'s pattern.',
  },
  {
    question: 'Do you offer extended sizing for taller or larger men\'s players?',
    answer: 'Yes. Men\'s jerseys are available up to 4XL, and for players who are tall but not necessarily a larger chest size, we can add body length as a custom modification. A 6\'5" outside hitter and a 5\'10" setter with a larger chest both have different fit needs — our order form includes optional customization fields for body length extensions.',
  },
  {
    question: 'What is the difference between relaxed and athletic fit for competitive play?',
    answer: 'Athletic fit jerseys move with the body during high-reach plays — serves, blocks, and arm swings — without excess fabric bunching under the armpit. Relaxed fit provides more freedom for players who feel restricted by form-fitting garments. For competitive leagues, athletic fit is generally preferred by coaches because it gives referees a clear visual of the player\'s body position during close calls.',
  },
  {
    question: 'Where are numbers placed on men\'s volleyball jerseys?',
    answer: 'Standard placement for men\'s volleyball jerseys is front chest center and back center. The NFHS requires a minimum 4-inch number height on the front and 6-inch on the back. We produce all numbers to meet these standards by default. Some programs opt for larger back numbers (up to 8 inches) for maximum visibility in large arenas.',
  },
  {
    question: 'Can men\'s jerseys be ordered with matching shorts for a complete uniform?',
    answer: 'Yes — and we recommend ordering them together. Matching shorts are produced in the same production run as jerseys, ensuring color batch consistency. Men\'s shorts are available with multiple inseam options ranging from 5 to 9 inches. Visit our <a href="/men-volleyball-uniforms/">men\'s volleyball uniforms</a> page for complete set pricing and inseam options.',
  },
  {
    question: 'We\'re a club with three men\'s teams at different competitive levels — can we order all three in a single order?',
    answer: 'Absolutely. Multi-team orders are common for clubs. You can choose identical designs across all three squads for a unified club identity, or differentiate squads with color variations — for example, a primary color scheme for the A team and a secondary color scheme for B and C teams. All three sets would be produced simultaneously, and we provide separated packaging by team.',
  },
  {
    question: 'Is your fabric appropriate for both indoor and beach volleyball?',
    answer: 'Our standard 4.5 oz polyester interlock is optimized for indoor court play. For beach volleyball, where jerseys must contend with sand abrasion, UV exposure, and salt water, we recommend our outdoor-grade mesh fabric which adds UV protection and dries faster after water contact. Specify beach or outdoor use when requesting a quote so we can recommend the appropriate fabric option.',
  },
  {
    question: 'What is the rush production timeline for a men\'s club jersey order?',
    answer: 'Standard production for men\'s club jersey orders is 14–18 business days after artwork approval. Rush production compresses this to 7–10 business days for an additional fee. For a typical club order of 12–18 jerseys with names and numbers, we recommend submitting your complete roster and artwork at least four weeks before you need the jerseys in hand.',
  },  { question: 'Do you offer extended body length options for tall men\'s volleyball players?', answer: 'Yes. Players who are tall relative to their chest measurement — common among outside hitters and middle blockers — can request a body length extension of up to 3 inches added to any standard size. This prevents the jersey from pulling untucked during jump serves and spike approaches without adding unnecessary width. Specify the required extension in inches when submitting your size roster.' },
  { question: 'Can men\'s volleyball jerseys be ordered with side hem slits for lateral mobility?', answer: 'Yes. Side slits from the hem up to the hip are a popular option for men\'s competition jerseys — they provide additional freedom of movement during wide lateral defensive steps and quick directional changes. Specify the slit depth (typically 3–5 inches) when requesting your design mockup and our team will incorporate it into the jersey pattern.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: "Men's Volleyball Jerseys",
  description: "Custom men's volleyball jerseys in athletic and relaxed fits with full sublimation and moisture-wicking polyester.",
  brand: { '@type': 'Brand', name: 'The Volleyball Uniforms' },
  url: `https://thevolleyballuniforms.com/${product.slug}/`,
  image: product.images.map(img => `https://thevolleyballuniforms.com${img}`),
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    price: '18.00',
    priceValidUntil: '2027-12-31',
    url: `https://thevolleyballuniforms.com/${product.slug}/`,
    seller: { '@type': 'Organization', name: 'The Volleyball Uniforms', url: 'https://thevolleyballuniforms.com' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '89' , bestRating: '5', worstRating: '1' },
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Volleyball Jerseys', href: '/volleyball-jerseys/' },
  { label: "Men's Volleyball Jerseys" },
];
import InlineQuoteSection from '../../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Men's Volleyball Jerseys — Custom Performance Designs | The Volleyball Uniforms"
  description="Custom men's volleyball jerseys in athletic and relaxed fits. Full sublimation, moisture-wicking polyester, bulk pricing for clubs & leagues. Get a free quote."
  schema={schema}
  canonical="https://thevolleyballuniforms.com/men-volleyball-jerseys/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <ProductGallery images={product.images} productName={product.name} />
        <div>
          <div class="text-sm text-electric-600 font-semibold mb-2">Volleyball Jerseys</div>
          <h1 class="text-4xl font-extrabold text-navy-950 mb-4 leading-tight">Men's Volleyball Jerseys</h1>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">{[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <span class="text-sm text-gray-500">4.8 / 5 (89 reviews)</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-6">Cut and constructed for male athletes, our men's volleyball jerseys deliver unrestricted range of motion for serves, spikes, and blocks while maintaining a sharp, professional appearance on the court. Available in athletic and relaxed fit, fully sublimated in your team colors, and built on moisture-wicking polyester that performs from the first serve to the final point.</p>
          <div class="space-y-3 mb-8">
            {['Men\'s-specific athletic and relaxed cut options', 'Extended torso and wider shoulder construction', 'Full dye-sublimation printing', 'Moisture-wicking 4.5 oz polyester', 'Sizes S through 4XL', 'Matching shorts available for complete sets'].map(f => (
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-electric-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {f}
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary w-full justify-center mb-4">Request a Quote</a>
          <a href="/size-guide/" class="btn-outline w-full justify-center text-sm">View Size Guide</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 prose-custom">
      <h2>Why Men's Volleyball Deserves a Purpose-Built Jersey</h2>
      <p>The mechanics of men's volleyball — higher net heights, powerful spike approaches, and aggressive blocking postures — place distinct demands on jersey design. A jersey that fits a female athlete's build and movement pattern won't provide optimal performance for a male player with a broader shoulder span and longer torso. Our men's volleyball jerseys are patterned from scratch for the male athletic form, not adapted from a generic unisex template. The result is a jersey that stays tucked during jump serves, doesn't bunch under the armpit during arm swings, and maintains a professional silhouette throughout a three-set match.</p>

      <h2>Athletic vs. Relaxed Fit — Making the Right Choice</h2>
      <p>The choice between athletic and relaxed fit comes down to position, playing style, and personal preference. Middle blockers and outside hitters often prefer athletic fit because the trimmer silhouette reduces interference with the net during tight blocking plays. Setters and liberos who prioritize lateral speed sometimes prefer relaxed fit for the additional freedom of movement. For adult recreational leagues where comfort is the priority, relaxed fit is the consistent crowd favorite.</p>
      <h3>Sizing for All Body Types in Men's Volleyball</h3>
      <p>Men's volleyball rosters can span a remarkable range of body types — from lean defensive specialists to larger, powerful right-side hitters. We offer sizes S through 4XL, plus custom body length extensions for players who are tall relative to their chest measurement. Use our detailed measurement guide in the <a href="/size-guide/">size guide</a> to ensure every player on your roster receives a properly fitting jersey regardless of where they land on the size spectrum.</p>

      <h2>Material and Fabric Details</h2>
      <p>Men's volleyball jerseys are produced on a 4.5 oz performance polyester interlock with integrated moisture-wicking. During intense men's volleyball play — which often features longer rallies, stronger attacks, and physical defensive work — players generate significant body heat. The moisture-wicking finish pulls sweat away from the skin and moves it to the fabric surface where it evaporates faster, keeping players drier and more comfortable through extended match situations. The interlock construction also resists the pilling that lighter jersey fabrics develop after repeated use.</p>

      <h2>Customization Options</h2>
      <p>Men's volleyball jerseys support the full range of sublimation customization: team colors (unlimited via sublimation), gradient and pattern effects, club or school logos, sponsor marks, player names, and numbers. Many men's club programs choose bold, graphic designs that reflect the competitive identity of the club. Submit your design concept or existing artwork through our <a href="/request-a-quote/">quote form</a> and our designers will develop a mockup within 2–3 business days.</p>

      <h2>Sizing Information</h2>
      <p>Men's jerseys are available in sizes S through 4XL with the men's athletic cut. For players requiring a longer body length than standard, we offer a custom length extension option that adds up to 3 inches to the torso. All size-specific adjustments maintain consistent number placement relative to the jersey's proportions. Check our <a href="/size-guide/">men's volleyball jersey sizing guide</a> for chest, shoulder, and length measurements corresponding to each size.</p>

      <h2>Bulk Order Benefits</h2>
      <p>Men's club programs, college programs, and adult league coordinators all benefit from bulk pricing tiers that begin at 10 jerseys. Clubs with A, B, and C men's teams can combine all squads into a single order for maximum discount. We also support seasonal re-orders at reduced pricing when a new player joins the roster mid-year — we keep your artwork on file and produce a single matching jersey on demand.</p>

      <h2>Use Cases</h2>
      <ul>
        <li>Men's club volleyball teams competing in USA Volleyball sanctioned leagues and tournaments</li>
        <li>College men's club programs outfitting for NCVF regional and national championships</li>
        <li>Adult recreational co-rec or men's-only volleyball leagues seeking uniform standardization</li>
        <li>High school boys volleyball programs in states where the sport is sanctioned by NFHS</li>
        <li>Corporate or social volleyball leagues requiring matching jerseys for team events</li>
      </ul>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <SpecsTable specs={specs} title="Men's Volleyball Jerseys Specifications" />
    </div>
  </section>

  <FAQSection faqs={faqs} title="Men's Volleyball Jerseys FAQs" />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-navy-950 mb-8">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map(p => <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />)}
      </div>
    </div>
  </section>

  <InlineQuoteSection productName={product.name} />


  <CTASection title="Gear Up Your Men's Program" subtitle="Free mockup, bulk pricing, and athletic cuts made specifically for men's volleyball." />
</BaseLayout>
