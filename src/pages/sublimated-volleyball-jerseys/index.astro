---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const product = products.find(p => p.slug === 'sublimated-volleyball-jerseys')!;
const related = products.filter(p => ['personalized-volleyball-jerseys','custom-name-volleyball-jerseys','volleyball-warm-up-suits','women-volleyball-jerseys'].includes(p.slug));

const specs = [
  { label: 'Printing Method', value: 'Dye-Sublimation (infused into fabric)' },
  { label: 'Primary Material', value: '100% Performance Polyester' },
  { label: 'Fabric Weight', value: '150–170 GSM' },
  { label: 'Color Options', value: 'Unlimited — full Pantone spectrum' },
  { label: 'Design Area', value: 'Full edge-to-edge, front and back' },
  { label: 'Fit Options', value: 'Relaxed, Athletic, or Compression' },
  { label: 'Sizes Available', value: 'YXS – 4XL' },
  { label: 'Customization', value: 'Names, numbers, logos, gradients, photographic imagery' },
  { label: 'Care', value: 'Machine wash cool inside-out, tumble dry low, no bleach' },
];

const faqs = [
  { question: 'What is dye-sublimation printing and how does it work?', answer: 'Dye-sublimation uses heat and pressure to convert solid dye into a gas that penetrates and permanently bonds with polyester fibers. The color becomes part of the fabric itself rather than sitting on the surface. This means the design cannot crack, peel, fade, or wash out — ever.' },
  { question: 'How many colors can I use in my sublimated jersey design?', answer: 'Unlimited. Unlike screen printing which charges per color, sublimation supports every color in the visible spectrum at no additional cost per color. Gradients, multiple tones, and complex multi-color artwork are all included at the same base price.' },
  { question: 'Will sublimated colors fade after repeated washing?', answer: 'No. Sublimated colors are permanently bonded into the fabric fibers, not printed on top. After hundreds of wash cycles under proper care conditions, the colors remain as vivid as day one. This is one of the key advantages of sublimation over screen printing or heat transfer methods.' },
  { question: 'Can sublimated jerseys include photographic or gradient designs?', answer: 'Yes. Sublimation supports photographic imagery, smooth gradients, watercolor effects, and any other design element that can be created in design software. These effects are included at no extra cost. They are completely impossible with traditional screen printing.' },
  { question: 'Do you need polyester fabric for sublimation printing?', answer: 'Yes. Dye-sublimation only works on polyester (and certain synthetic blends with a high polyester content). It does not work on cotton. All our sublimated jerseys use 100% performance polyester specifically chosen for sublimation compatibility.' },
  { question: 'What is the minimum order quantity for sublimated jerseys?', answer: 'There is no minimum order. We produce single sublimated jerseys as well as orders of 500+. However, orders of 12 or more units benefit from our bulk pricing tiers, and orders of 24+ receive our best standard rates.' },
  { question: 'Can sublimated jerseys be produced with individual player names and numbers on each piece?', answer: 'Yes. Player-specific names and numbers are sublimated into each jersey individually. You submit a roster and each jersey is produced with that specific player\'s information. There is no per-player upcharge — individual personalization is included in the standard sublimation price.' },
  { question: 'How long does it take to produce sublimated volleyball jerseys?', answer: 'Standard production takes 10–14 business days after you approve the design mockup. Rush production in 5–7 business days is available. The design mockup phase typically takes 1–3 business days. Rush fees apply for expedited production.' },  { question: 'Can I order a single sample jersey before committing to a full team order?', answer: 'Yes. Sample jerseys are available and strongly recommended for programs ordering sublimated jerseys for the first time. A sample order lets you verify color accuracy, fabric feel, and fit before your full roster order enters production. Sample turnaround follows standard production timing. The cost of the sample jersey applies as a credit toward your full team order.' },
  { question: 'How accurately can you match our school or club\'s specific Pantone colors?', answer: 'We use high-precision sublimation equipment calibrated to standard Pantone profiles. For programs with strict institutional color standards, provide your Pantone PMS codes and we produce a sample print panel at no charge to verify color accuracy before full production begins. Minor variation between screen display and physical fabric is normal — the print panel eliminates any color surprise before your full order.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Sublimated Volleyball Jerseys',
  description: 'Premium dye-sublimated volleyball jerseys with permanent full-color designs. Unlimited colors, edge-to-edge printing, player names and numbers included.',
  brand: { '@type': 'Brand', name: 'The Volleyball Uniforms' },
  url: `https://thevolleyballuniforms.com/${product.slug}/`,
  image: product.images.map(img => `https://thevolleyballuniforms.com${img}`),
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    price: '18.00',
    priceValidUntil: '2027-12-31',
    url: `https://thevolleyballuniforms.com/${product.slug}/`,
    seller: { '@type': 'Organization', name: 'The Volleyball Uniforms', url: 'https://thevolleyballuniforms.com' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '186' , bestRating: '5', worstRating: '1' },
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Volleyball Jerseys', href: '/volleyball-jerseys/' },
  { label: 'Sublimated Volleyball Jerseys' },
];
import InlineQuoteSection from '../../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Sublimated Volleyball Jerseys — Full Color Custom Designs | The Volleyball Uniforms"
  description="Premium sublimated volleyball jerseys with permanent full-color designs. Unlimited colors, edge-to-edge printing, never crack or fade. Bulk pricing. Free mockup. Get a quote."
  schema={schema}
  canonical="https://thevolleyballuniforms.com/sublimated-volleyball-jerseys/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <ProductGallery images={product.images} productName={product.name} />
        <div>
          <div class="text-sm text-electric-600 font-semibold mb-2">Volleyball Jerseys</div>
          <h1 class="text-4xl font-extrabold text-navy-950 mb-4 leading-tight">Sublimated Volleyball Jerseys</h1>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">{[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <span class="text-sm text-gray-500">4.9 / 5 (186 reviews)</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-6">The gold standard in custom volleyball jersey production. Dye-sublimation printing creates permanent, vibrant designs infused directly into the fabric — unlimited colors, zero cracking, zero fading, season after season.</p>
          <div class="space-y-3 mb-8">
            {['Unlimited colors at no extra cost per color','Permanent dye — never cracks, peels, or fades','Full edge-to-edge design coverage','Gradient and photographic design support','Player names & numbers included in sublimation','Available in sizes YXS – 4XL'].map(f => (
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-electric-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {f}
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary w-full justify-center mb-4">Request a Quote</a>
          <a href="/design-guide/" class="btn-outline w-full justify-center text-sm">View Design Guide</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 prose-custom">
      <h2>How Dye-Sublimation Printing Actually Works</h2>
      <p>Dye-sublimation is a heat-transfer process that converts solid dye into a gas under high temperature and pressure, allowing the dye molecules to penetrate open polyester fibers. When the heat is removed, the fibers close around the dye molecules and trap them permanently inside the fabric structure. The result is color that exists inside the fabric rather than on its surface. This is the fundamental mechanical difference between sublimation and every other printing method — screen printing, heat transfer, and DTF all deposit material on top of the fabric surface, which means they can eventually crack, peel, or separate. Sublimated color cannot delaminate because there is no layer to delaminate. All of our custom <a href="/volleyball-jerseys/">volleyball jerseys</a> are produced using this process on 100% performance polyester fabrics specifically selected for sublimation compatibility.</p>

      <h2>Design Possibilities That Only Sublimation Can Achieve</h2>
      <p>Screen printing is constrained by color count — each color requires a separate screen, and the cost compounds as complexity grows. Sublimation has no such constraint. A gradient that transitions through twelve color values costs the same to produce as a solid single-color design. Photorealistic imagery, smooth color fades across panel seams, full-bleed designs that extend edge-to-edge without borders, and complex geometric patterns with precise color registration are all standard capabilities. Programs that use school-specific Pantone colors can request color accuracy verification through a sample print panel before full production begins. Visit our <a href="/design-guide/">volleyball uniform design guide</a> for artwork preparation specifications.</p>

      <h2>Why Sublimation Outlasts Every Other Volleyball Jersey Decoration Method</h2>
      <p>Heat transfer vinyl applied to a volleyball jersey begins failing at its edges after repeated high-heat washing cycles. Screen-printed plastisol inks crack at flex points — armpits, back numbers, front logos — when the jersey is used aggressively for sport and washed frequently. Tackle twill and embroidered patches hold longer but add surface texture that affects jersey drape and creates abrasion points on contact. Sublimation has no degradation mechanism under normal use conditions. The dye is bonded at a molecular level with the polyester substrate, and the only force capable of affecting it is UV exposure over years — which gym-use jerseys rarely encounter at levels that cause visible change. For programs that need jerseys to last through multiple competitive seasons, sublimation is the clear choice. See our <a href="/personalized-volleyball-jerseys/">personalized volleyball jerseys</a> for sublimation with individual player names on every piece.</p>

      <h2>Color Accuracy in Sublimation: Managing Expectations Correctly</h2>
      <p>Sublimated colors on polyester fabric appear differently than the same colors on a screen or on paper. Polyester's white base reflects light differently than coated paper, and the gas-phase dye transfer saturates colors in a way that can shift hues slightly from a standard Pantone reference. Programs with strict institutional color standards should request a sample print panel before committing to full production — we calibrate our equipment to standard Pantone profiles and provide the panel at no charge for compliance-sensitive orders. Color variation between jersey fabric and shorts fabric is also possible if the two garments use different fabric constructions, which is another reason we recommend ordering jersey and shorts together rather than from different sources.</p>

      <h2>Sublimation vs. Screen Print: A Direct Comparison for Volleyball Programs</h2>
      <p>Screen printing has real advantages in specific contexts — it works on cotton and mixed fabrics, it's available same-day from local decorators, and for very simple one-color logo applications it can be cost-effective. For volleyball jerseys specifically, its disadvantages are significant: it requires separate runs for each color, cannot reproduce gradients or photographic imagery, creates an ink layer that cracks with athletic stress and frequent washing, and cannot match the color accuracy achievable with sublimation on polyester. For any program ordering jerseys intended for competitive use over more than one season, sublimation produces a better outcome at comparable or lower cost when order quantities reach team scale. Contact us for a direct pricing comparison for your order size and design requirements.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <SpecsTable specs={specs} title="Sublimated Volleyball Jersey Specifications" />
    </div>
  </section>

  <FAQSection faqs={faqs} title="Sublimated Volleyball Jersey FAQs" />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-navy-950 mb-8">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {related.map(p => <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />)}
      </div>
    </div>
  </section>

  <InlineQuoteSection productName={product.name} />


  <CTASection title="Ready to Design Your Sublimated Jerseys?" subtitle="Get a free full-color design mockup and competitive quote within 1–2 business hours." />
</BaseLayout>
