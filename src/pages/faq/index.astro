---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'FAQ' }];

const orderFaqs = [
  { question: 'How do I place an order?', answer: 'The ordering process starts with a quote request. Fill out our quote form at /request-a-quote/ with your team details, product needs, and any design ideas. We respond within 1–2 business hours with pricing and next steps.' },
  { question: 'Is there a minimum order quantity?', answer: 'No. We produce single jerseys as well as orders of 500+. However, ordering 12 or more units unlocks our bulk pricing tiers for better per-unit costs.' },
  { question: 'How long does production take?', answer: 'Standard production is 10–14 business days after design approval. Rush production is available in 5–7 business days. These timelines begin after you sign off on the design mockup.' },
  { question: 'Can I make changes after approving the design?', answer: 'Once you sign the production approval form, design changes cannot be made without restarting production. We strongly encourage thorough review of all mockups before signing off.' },
  { question: 'Do you ship internationally?', answer: 'Our primary market is the United States. For international orders, please contact us directly to discuss shipping options, timelines, and any additional requirements.' },
];

const designFaqs = [
  { question: 'Is the design mockup really free?', answer: 'Yes. Every quote includes a complimentary digital design mockup. There is no obligation to place an order after receiving your mockup.' },
  { question: 'What if I do not have a logo or design?', answer: 'Our design team can create a custom design from scratch based on your description, color preferences, and reference images. This is included in the design process at no additional cost.' },
  { question: 'How many revisions can I request?', answer: 'Unlimited. We revise your mockup as many times as necessary until you are completely satisfied. Most orders are finalized within 2–3 rounds.' },
  { question: 'What file formats do you accept for logos?', answer: 'We prefer vector files: AI, EPS, SVG, or vector PDF. For raster files, we need PNG or JPG at 300 DPI or higher. If you only have low-resolution files, our designers can recreate your logo.' },
];

const productFaqs = [
  { question: 'What is sublimation printing?', answer: 'Dye-sublimation is a printing process that uses heat to transfer dye directly into polyester fabric fibers. The result is vibrant, permanent color that cannot crack, peel, or fade — even after hundreds of washes. It supports unlimited colors and edge-to-edge designs.' },
  { question: 'What fabrics do you use for volleyball jerseys?', answer: 'Our standard fabric is 100% moisture-wicking polyester. We also offer 88/12 or 90/10 polyester-spandex blends for added stretch. Both are suitable for competitive play and machine washable.' },
  { question: 'Do you make libero jerseys?', answer: 'Yes. Libero jerseys in a contrasting color matching your team\'s design language are available as part of any uniform order. They are produced with the same care and quality as your standard team jerseys.' },
  { question: 'Can I order jerseys and shorts together?', answer: 'Absolutely. Complete volleyball uniform sets (jersey + shorts) are our most popular order type. We also offer complete team kits that include warm-up suits, hoodies, practice jerseys, and socks.' },
  { question: 'Do warm-up suits fit over game uniforms?', answer: 'Yes. Our volleyball warm-up suits are designed to be worn over game jerseys and shorts. The jacket has a relaxed cut that slides on and off easily, even over tight athletic wear.' },
];

const sizingFaqs = [
  { question: 'How do I collect sizes for a team order?', answer: 'We recommend having each player measure their chest circumference. Use our downloadable size chart at /size-guide/ to convert measurements to sizes. Submit the size roster along with your quote request.' },
  { question: 'What if I make a sizing mistake after ordering?', answer: 'If a sizing error is identified before production begins, we can correct it at no charge. After production, size exchanges are evaluated case by case. We recommend double-checking all sizes before approving the order.' },
  { question: 'Do you offer custom dimensions for players who do not fit standard sizing?', answer: 'Yes. Custom sizing (also called cut-and-sew custom) is available for players who fall outside our standard size range. This typically adds 3–5 business days to production time and may incur a small per-unit premium.' },
];
---

<BaseLayout
  title="Volleyball Uniforms FAQ — Ordering, Design & Sizing | The Volleyball Uniforms"
  description="Frequently asked questions about custom volleyball uniforms. Ordering process, design options, sizing, fabrics, timelines & more. Get answers before requesting a quote."
  canonical="https://thevolleyballuniforms.com/faq/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="bg-gradient-to-br from-navy-950 to-navy-800 py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-5xl font-extrabold text-white mb-4">Frequently Asked Questions</h1>
      <p class="text-xl text-navy-300">Answers to the most common questions about ordering custom volleyball uniforms from The Volleyball Uniforms.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-wrap gap-3 justify-center mb-12">
        {[
          { label: 'Ordering', href: '#ordering' },
          { label: 'Design', href: '#design' },
          { label: 'Products', href: '#products' },
          { label: 'Sizing', href: '#sizing' },
        ].map(tab => (
          <a href={tab.href} class="px-5 py-2 rounded-full border border-navy-200 text-navy-700 font-medium hover:bg-navy-950 hover:text-white hover:border-navy-950 transition-all text-sm">
            {tab.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <div id="ordering" class="scroll-mt-24">
    <FAQSection faqs={orderFaqs} title="Ordering Process" />
  </div>
  <div id="design" class="scroll-mt-24">
    <FAQSection faqs={designFaqs} title="Design & Customization" />
  </div>
  <div id="products" class="scroll-mt-24">
    <FAQSection faqs={productFaqs} title="Products & Materials" />
  </div>
  <div id="sizing" class="scroll-mt-24">
    <FAQSection faqs={sizingFaqs} title="Sizing & Fit" />
  </div>

  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-extrabold text-navy-950 mb-4">Still Have Questions?</h2>
      <p class="text-gray-600 mb-6">Our team is available Monday–Friday, 9 AM–6 PM ET. We typically respond to emails within 1–2 hours.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="btn-outline">Contact Us</a>
        <a href="/request-a-quote/" class="btn-primary">Request a Quote</a>
      </div>
    </div>
  </section>

  <CTASection title="Ready to Get Started?" subtitle="Request a free quote and design mockup for your volleyball team's uniforms." />
</BaseLayout>
