---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import CTASection from '../components/CTASection.astro';
import FAQSection from '../components/FAQSection.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import { products, categories } from '../data/products';

const featuredProducts = products.slice(0, 8);

const homeFaqs = [
  { question: 'What is the minimum order quantity for custom volleyball uniforms?', answer: 'We welcome orders of all sizes. Whether you need 6 jerseys for a small club team or 200 uniforms for a large league, we can accommodate your order. Larger quantities receive better pricing per unit.' },
  { question: 'How long does it take to receive custom volleyball uniforms?', answer: 'Standard production takes 10–14 business days after design approval. Rush orders can be completed in 5–7 business days for an additional fee. We always confirm your delivery timeline before production begins.' },
  { question: 'Can I see a design mockup before placing my order?', answer: 'Yes. We provide a free digital design mockup for every order before production begins. You can request revisions until you are completely satisfied with the design.' },
  { question: 'What customization options are available?', answer: 'We offer full sublimation printing, screen printing, heat transfer, and embroidery. You can customize team colors, player names, numbers, logos, sponsor graphics, and more. Our design team will guide you through every option.' },
  { question: 'Do you offer complete team packages?', answer: 'Absolutely. Our volleyball team kits can include jerseys, shorts, warm-up suits, hoodies, socks, and bags — everything your team needs in one coordinated order. Contact us to build a custom package.' },
  { question: 'What fabric options are available for volleyball jerseys?', answer: 'We use premium moisture-wicking 100% polyester and polyester-spandex blends engineered for volleyball movement — stretchy, breathable, and quick-drying. Fabric details are listed on each product page.' },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'LocalBusiness'],
  name: 'The Volleyball Uniforms',
  url: 'https://thevolleyballuniforms.com',
  logo: 'https://thevolleyballuniforms.com/favicon.svg',
  description: 'Premium custom volleyball uniforms, jerseys, and team apparel for schools, colleges, clubs, and leagues.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '245 W 29th St',
    addressLocality: 'New York',
    addressRegion: 'NY',
    postalCode: '10001',
    addressCountry: 'US',
  },
  telephone: '+12125550198',
  email: 'Info@thevolleyballuniforms.com',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'The Volleyball Uniforms',
  url: 'https://thevolleyballuniforms.com',
  description: 'Custom volleyball uniforms, jerseys, and team apparel for schools, colleges, clubs, and leagues across the United States.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://thevolleyballuniforms.com/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
import InlineQuoteSection from '../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Custom Volleyball Uniforms & Jerseys | The Volleyball Uniforms"
  description="Premium custom volleyball uniforms, jerseys & team apparel for schools, colleges & clubs. Bulk orders, free design mockups, fast turnaround. Request a quote today."
  schema={[orgSchema, websiteSchema]}
  canonical="https://thevolleyballuniforms.com/"
>
  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-navy-950 via-navy-900 to-electric-900 overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 left-10 w-96 h-96 rounded-full bg-gold-400/10 blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-[500px] h-[500px] rounded-full bg-electric-500/10 blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/5"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-28 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-gold-500/20 text-gold-300 text-sm font-semibold px-4 py-2 rounded-full mb-8 border border-gold-500/30">
            <span class="w-2 h-2 bg-gold-400 rounded-full animate-pulse"></span>
            Trusted by 500+ Teams Across the USA
          </div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-none mb-6">
            Premium Custom<br/>
            <span class="text-gold-400">Volleyball</span><br/>
            Uniforms
          </h1>
          <p class="text-xl text-navy-300 mb-10 max-w-xl leading-relaxed">
            From youth leagues to college programs, we craft high-performance volleyball uniforms built to your exact specifications. Free design mockup. Bulk discounts. Fast delivery.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/request-a-quote/" class="btn-primary text-base">
              Get a Free Quote
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/volleyball-jerseys/" class="btn-secondary text-base">Browse All Products</a>
          </div>
          <div class="flex flex-wrap gap-6 mt-10 text-sm text-navy-400">
            {['Free Design Mockup', 'No Hidden Fees', 'Rush Orders Available', '100% Satisfaction Guaranteed'].map(t => (
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {t}
              </span>
            ))}
          </div>
        </div>
        <div class="hidden lg:grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="overflow-hidden rounded-2xl aspect-[3/4] bg-navy-800">
              <img src="/images/women-volleyball-jerseys/1.jpg" alt="Custom women's volleyball jerseys" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity" loading="eager" width="400" height="533" />
            </div>
            <div class="overflow-hidden rounded-2xl aspect-square bg-navy-800">
              <img src="/images/volleyball-team-kits/1.jpg" alt="Volleyball team kit packages" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity" loading="eager" width="400" height="400" />
            </div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="overflow-hidden rounded-2xl aspect-square bg-navy-800">
              <img src="/images/sublimated-volleyball-jerseys/1.jpg" alt="Sublimated volleyball jerseys" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity" loading="eager" width="400" height="400" />
            </div>
            <div class="overflow-hidden rounded-2xl aspect-[3/4] bg-navy-800">
              <img src="/images/men-volleyball-uniforms/1.jpg" alt="Men's volleyball uniforms" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity" loading="eager" width="400" height="533" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-white border-b border-gray-100 py-5">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { emoji: '🎨', title: 'Free Design Mockup', desc: 'See your design before you pay' },
          { emoji: '📦', title: 'Bulk Order Discounts', desc: 'Better pricing for larger orders' },
          { emoji: '⚡', title: 'Rush Orders', desc: 'As fast as 5–7 business days' },
          { emoji: '✅', title: '100% Satisfaction', desc: 'We make it right, guaranteed' },
        ].map(b => (
          <div class="flex items-center gap-3">
            <span class="text-3xl">{b.emoji}</span>
            <div>
              <div class="font-bold text-navy-950 text-sm">{b.title}</div>
              <div class="text-gray-500 text-xs">{b.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="section-title">Shop by Category</h2>
        <p class="section-subtitle mx-auto">Everything your volleyball team needs — from game-day uniforms to practice gear and team apparel.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5">
        {categories.map((cat, i) => {
          const icons = ['🏐', '👕', '🎽', '🧥', '📦'];
          return (
            <a href={`/${cat.slug}/`} class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 border border-gray-100 text-center block">
              <div class="w-16 h-16 bg-navy-50 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-navy-950 transition-colors duration-300">
                <span class="text-2xl">{icons[i]}</span>
              </div>
              <h3 class="font-bold text-navy-950 mb-1.5 group-hover:text-electric-600 transition-colors">{cat.name}</h3>
              <p class="text-gray-500 text-xs line-clamp-2 leading-relaxed mb-3">{cat.description}</p>
              <span class="inline-flex items-center gap-1 text-xs font-semibold text-electric-600 group-hover:gap-2 transition-all">
                {cat.products.length} products
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-end justify-between mb-14">
        <div>
          <h2 class="section-title">Featured Products</h2>
          <p class="section-subtitle">Our most popular custom volleyball uniforms and jerseys.</p>
        </div>
        <a href="/volleyball-jerseys/" class="hidden md:flex items-center gap-2 text-electric-600 font-semibold hover:text-electric-700 transition-colors whitespace-nowrap">
          View All
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredProducts.map(p => (
          <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />
        ))}
      </div>
    </div>
  </section>

  <!-- CUSTOM UNIFORMS FEATURE -->
  <section class="py-20 bg-navy-950">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-gold-500/20 text-gold-300 text-sm font-semibold px-4 py-2 rounded-full mb-6 border border-gold-500/30">
            100% Custom Design
          </div>
          <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight">Your Design.<br/>Your Colors.<br/>Your Identity.</h2>
          <p class="text-navy-300 text-lg leading-relaxed mb-8">
            Every uniform we produce is made to order. Submit your artwork, choose your colors, and we handle the rest — from design approval to final delivery. Our <a href="/sublimated-volleyball-jerseys/" class="text-gold-400 hover:text-gold-300 underline underline-offset-2">sublimated volleyball jerseys</a> offer unlimited color and design possibilities with no extra cost per color.
          </p>
          <ul class="space-y-4 mb-10">
            {[
              'Full-color sublimation printing on every uniform',
              'Custom team logos, names, and player numbers',
              'Pantone color matching available',
              'Consistent sizing across your entire roster',
              'Free design revisions until you approve',
            ].map(item => (
              <li class="flex items-center gap-3 text-navy-200 text-sm">
                <svg class="w-5 h-5 text-gold-400 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/design-guide/" class="btn-primary">View Design Guide</a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/images/custom-name-volleyball-jerseys/1.jpg" alt="Custom name volleyball jerseys" class="w-full h-full object-cover" loading="lazy" width="400" height="533" />
          </div>
          <div class="space-y-4">
            <div class="overflow-hidden rounded-2xl aspect-square">
              <img src="/images/sublimated-volleyball-jerseys/2.jpg" alt="Sublimated volleyball jersey designs" class="w-full h-full object-cover" loading="lazy" width="300" height="300" />
            </div>
            <div class="overflow-hidden rounded-2xl aspect-square">
              <img src="/images/personalized-volleyball-jerseys/1.jpg" alt="Personalized volleyball jerseys" class="w-full h-full object-cover" loading="lazy" width="300" height="300" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BULK ORDERS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="grid grid-cols-2 gap-4 order-2 lg:order-1">
          <div class="overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/images/volleyball-team-kits/2.jpg" alt="Volleyball team kits bulk order" class="w-full h-full object-cover" loading="lazy" width="400" height="533" />
          </div>
          <div class="space-y-4">
            <div class="overflow-hidden rounded-2xl aspect-square">
              <img src="/images/volleyball-warm-up-suits/1.jpg" alt="Volleyball warm up suits for teams" class="w-full h-full object-cover" loading="lazy" width="300" height="300" />
            </div>
            <div class="overflow-hidden rounded-2xl aspect-square">
              <img src="/images/volleyball-hoodies/1.jpg" alt="Custom volleyball hoodies" class="w-full h-full object-cover" loading="lazy" width="300" height="300" />
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 bg-electric-100 text-electric-700 text-sm font-semibold px-4 py-2 rounded-full mb-6">
            Bulk Team Orders
          </div>
          <h2 class="section-title mb-6">Outfit Your Entire Team in One Order</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            Schools, clubs, colleges, and volleyball leagues across the country trust us for complete team uniform packages. Our <a href="/volleyball-team-kits/" class="text-electric-600 hover:text-electric-700 font-medium">volleyball team kits</a> include jerseys, shorts, warm-up gear, and accessories — all coordinated and discounted for bulk.
          </p>
          <div class="grid grid-cols-2 gap-4 mb-10">
            {[
              { n: '500+', l: 'Teams Served' },
              { n: '10K+', l: 'Uniforms Produced' },
              { n: '15+', l: 'Years Experience' },
              { n: '48hr', l: 'Quote Response' },
            ].map(s => (
              <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 text-center">
                <div class="text-3xl font-extrabold text-navy-950">{s.n}</div>
                <div class="text-gray-500 text-sm mt-1">{s.l}</div>
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary">Start Your Bulk Order</a>
        </div>
      </div>
    </div>
  </section>

  <!-- QUALITY & MATERIALS -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="section-title">Built for Performance on the Court</h2>
        <p class="section-subtitle mx-auto">We use only premium volleyball-specific fabrics and printing technologies that hold up through full seasons of competition.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '🧵',
            title: 'Performance Fabrics',
            desc: 'Moisture-wicking 100% polyester and polyester-spandex blends engineered for volleyball movement — stretchy, breathable, and quick-drying for long match days.',
            link: '/size-guide/',
            linkText: 'View Size Guide',
          },
          {
            icon: '🖨️',
            title: 'Dye-Sublimation Printing',
            desc: 'Colors are infused directly into fabric fibers — they cannot crack, peel, or fade. Full-color edge-to-edge printing at no extra cost per color.',
            link: '/sublimated-volleyball-jerseys/',
            linkText: 'See Sublimated Jerseys',
          },
          {
            icon: '📐',
            title: 'Team Sizing System',
            desc: 'Our proven sizing process ensures every player gets the right fit. Submit a size roster and we handle everything — no individual measurements needed.',
            link: '/size-guide/',
            linkText: 'Download Size Chart',
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:shadow-lg transition-all group">
            <div class="text-4xl mb-5">{item.icon}</div>
            <h3 class="text-xl font-bold text-navy-950 mb-3">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed mb-5 text-sm">{item.desc}</p>
            <a href={item.link} class="text-electric-600 font-semibold text-sm flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
              {item.linkText}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="py-20 bg-navy-950">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Why Teams Choose Us</h2>
        <p class="text-navy-400 text-lg max-w-2xl mx-auto">Over 15 years perfecting custom volleyball uniform production for teams at every level.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { emoji: '🎯', title: 'Exact-Match Colors', desc: 'Pantone color matching and digital proofing ensure your school or club colors are reproduced precisely.' },
          { emoji: '⚡', title: 'Fast Turnaround', desc: '10–14 day standard production with rush options for tight tournament and season deadlines.' },
          { emoji: '💰', title: 'Volume Pricing', desc: 'The more you order, the better the per-unit price. Perfect for leagues, schools, and multi-team clubs.' },
          { emoji: '🔄', title: 'Free Revisions', desc: 'We revise your design mockup as many times as needed until every detail is exactly right.' },
          { emoji: '📦', title: 'Individual Packaging', desc: 'Each uniform is sorted and labeled by player name or number for instant, organized distribution.' },
          { emoji: '🏆', title: 'Tournament-Grade Quality', desc: 'Our uniforms meet quality standards for high school, collegiate, and professional competition.' },
        ].map(item => (
          <div class="bg-navy-900 rounded-2xl p-7 border border-navy-800 hover:border-gold-500/40 transition-colors group">
            <div class="text-3xl mb-4">{item.emoji}</div>
            <h3 class="text-white font-bold text-lg mb-2 group-hover:text-gold-400 transition-colors">{item.title}</h3>
            <p class="text-navy-400 leading-relaxed text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="section-title">How the Order Process Works</h2>
        <p class="section-subtitle mx-auto">From quote to delivery in four clear steps — we make custom uniform ordering simple.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '01', title: 'Request a Quote', desc: 'Fill out our quote form with your team size, product needs, and any design ideas you have in mind.' },
          { step: '02', title: 'Free Design Mockup', desc: 'Our design team creates a free digital mockup. You review, request changes, and approve before we proceed.' },
          { step: '03', title: 'Production', desc: 'Once approved, we craft your uniforms using premium fabrics and professional printing equipment.' },
          { step: '04', title: 'Delivery to Your Door', desc: 'Your complete order is individually packaged and shipped directly to your school, club, or home address.' },
        ].map(item => (
          <div class="text-center">
            <div class="w-20 h-20 bg-navy-950 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">
              <span class="text-gold-400 font-extrabold text-xl">{item.step}</span>
            </div>
            <h3 class="font-bold text-navy-950 text-lg mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/request-a-quote/" class="btn-primary">Start the Process Today</a>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="section-title">Our Work Gallery</h2>
        <p class="section-subtitle mx-auto">Custom volleyball uniforms and jerseys we have produced for teams across the United States.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {[
          { src: '/images/women-volleyball-jerseys/1.jpg', alt: "Women's volleyball jersey" },
          { src: '/images/men-volleyball-uniforms/1.jpg', alt: "Men's volleyball uniform" },
          { src: '/images/sublimated-volleyball-jerseys/2.jpg', alt: 'Sublimated volleyball jersey' },
          { src: '/images/college-volleyball-uniforms/1.jpg', alt: 'College volleyball uniform' },
          { src: '/images/volleyball-warm-up-suits/1.jpg', alt: 'Volleyball warm up suit' },
          { src: '/images/custom-name-volleyball-jerseys/2.jpg', alt: 'Custom name volleyball jersey' },
          { src: '/images/youth-volleyball-uniforms/1.jpg', alt: 'Youth volleyball uniform' },
          { src: '/images/volleyball-hoodies/1.jpg', alt: 'Custom volleyball hoodie' },
          { src: '/images/high-school-volleyball-uniforms/1.jpg', alt: 'High school volleyball uniform' },
          { src: '/images/volleyball-team-kits/1.jpg', alt: 'Volleyball team kit' },
        ].map(img => (
          <div class="overflow-hidden rounded-xl aspect-square bg-gray-200 group">
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="300" height="300" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <TestimonialSection />

  <FAQSection faqs={homeFaqs} title="Common Questions About Custom Volleyball Uniforms" />

  <InlineQuoteSection />


  <CTASection
    title="Ready to Outfit Your Team?"
    subtitle="Get a free custom design mockup and competitive quote for your volleyball uniforms order. No obligation, no minimum."
    btnText="Get Your Free Quote Now"
  />
</BaseLayout>
