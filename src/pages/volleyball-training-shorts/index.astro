---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const product = products.find(p => p.slug === 'volleyball-training-shorts')!;
const related = products.filter(p => ['volleyball-practice-jerseys','volleyball-compression-shirts','volleyball-socks'].includes(p.slug));

const specs = [
  { label: 'Primary Material', value: '100% Polyester or 88/12 Polyester-Spandex blend' },
  { label: 'Fabric Weight', value: '130–150 GSM (lightweight)' },
  { label: 'Stretch', value: '4-way stretch available in spandex blend option' },
  { label: 'Inseam Options', value: '2", 3", 5", or 7" (specify on order)' },
  { label: 'Waistband', value: 'Elastic with internal drawstring' },
  { label: 'Fit Options', value: 'Loose athletic or compression/fitted' },
  { label: 'Sizes Available', value: 'YXS – 3XL' },
  { label: 'Customization', value: 'Team colors, logo, name/number optional' },
  { label: 'Care', value: 'Machine wash cool, tumble dry low' },
];

const faqs = [
  { question: 'What inseam lengths are available for volleyball training shorts?', answer: 'We offer inseam lengths of 2", 3", 5", and 7". The 2–3" inseam is standard for women\'s volleyball and provides maximum range of motion for lateral movement. The 5–7" inseam is popular with men\'s programs. You can specify different inseam lengths per player in a team order.' },
  { question: 'Should I choose loose-fit or compression training shorts?', answer: 'Loose-fit shorts in lightweight polyester are better for players who prefer unrestricted movement and airflow during training. Compression-fit shorts in a polyester-spandex blend provide muscle support and stay in place during aggressive floor movements. Many teams order both styles depending on individual player preferences.' },
  { question: 'Can training shorts be customized with team colors?', answer: 'Yes. Training shorts can be fully sublimated in your team colors with optional logo, side stripe, or text elements. Coordinating your practice shorts with practice jerseys creates a professional, organized training environment. See our volleyball practice jerseys for matching tops.' },
  { question: 'Do training shorts differ from game shorts?', answer: 'Game shorts are typically produced with the same sublimation design as the matching game jersey for a coordinated uniform appearance. Training shorts are simpler in design — a consistent team color with basic branding — and are built to withstand more frequent washing and heavier use than game shorts.' },
  { question: 'Are pockets available in volleyball training shorts?', answer: 'Side slash pockets are available on 5" and 7" inseam loose-fit styles. Compression-style shorts typically do not include pockets as they interfere with the compression construction. Specify your pocket preference when requesting a quote.' },
  { question: 'Can I order training shorts with brief liners?', answer: 'Yes. Attached brief liners are popular in women\'s volleyball shorts, particularly for 2" and 3" inseam styles. Brief liners provide additional coverage during dynamic movements without adding bulk. Specify liner preference per player if needed, as some prefer shorts without liners.' },
  { question: 'What is the minimum order for custom training shorts?', answer: 'There is no minimum order. Single pairs can be produced for individual players. Team orders of 12 or more pairs receive bulk pricing. For programs ordering practice jerseys and shorts together, we offer combined practice gear package pricing.' },
  { question: 'How do training shorts hold up to daily washing?', answer: 'Our training shorts are built for daily use and frequent washing. The polyester construction maintains its shape and color vibrancy after repeated machine washing. We recommend a cool cycle and tumble dry low to maximize the lifespan of the garment and any sublimated designs.' },  { question: 'Can training shorts be ordered with zippered pockets?', answer: 'Side zippered pockets are available on 5-inch and 7-inch inseam loose-fit training shorts. The zipper closure secures small items during practice without affecting the shorts\' range of motion. Compression-fit styles do not include pockets as they interfere with the stretch construction. Specify your pocket preference when requesting a quote.' },
  { question: 'How do training shorts differ from game shorts?', answer: 'Training shorts use a simpler design — typically solid team color with minimal branding — and are built to withstand daily washing frequency and intensive use. Game shorts are produced with the same full sublimation design as the matching game jersey for a coordinated uniform appearance. Game shorts are generally reserved for competition to preserve their appearance, while training shorts handle the daily wear of every practice session throughout the season.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Volleyball Training Shorts',
  description: 'Lightweight volleyball training shorts with multiple inseam options and 4-way stretch for full range of motion during intensive volleyball practice.',
  brand: { '@type': 'Brand', name: 'The Volleyball Uniforms' },
  url: `https://thevolleyballuniforms.com/${product.slug}/`,
  image: product.images.map(img => `https://thevolleyballuniforms.com${img}`),
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    url: `https://thevolleyballuniforms.com/${product.slug}/`,
    seller: { '@type': 'Organization', name: 'The Volleyball Uniforms', url: 'https://thevolleyballuniforms.com' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.7', reviewCount: '57' , bestRating: '5', worstRating: '1' },
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Practice Gear', href: '/practice-gear/' },
  { label: 'Volleyball Training Shorts' },
];
import InlineQuoteSection from '../../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Volleyball Training Shorts — Lightweight Practice Shorts | The Volleyball Uniforms"
  description="Lightweight volleyball training shorts with 4-way stretch. Multiple inseam options, loose or compression fit. Custom team colors. Bulk pricing. Get a free quote today."
  schema={schema}
  canonical="https://thevolleyballuniforms.com/volleyball-training-shorts/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <ProductGallery images={product.images} productName={product.name} />
        <div>
          <div class="text-sm text-electric-600 font-semibold mb-2">Practice Gear</div>
          <h1 class="text-4xl font-extrabold text-navy-950 mb-4 leading-tight">Volleyball Training Shorts</h1>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">{[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <span class="text-sm text-gray-500">4.7 / 5 (57 reviews)</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-6">Volleyball training shorts engineered for full freedom of movement. Available in 2", 3", 5", and 7" inseam lengths with loose-fit or compression-fit options. Lightweight polyester or 4-way stretch blend in your team colors.</p>
          <div class="space-y-3 mb-8">
            {['Four inseam length options (2", 3", 5", 7")','Loose-fit or compression-fit options','Lightweight polyester or spandex blend fabric','Brief liner option for women\'s styles','Custom team colors and logo sublimation','Elastic waistband with internal drawstring'].map(f => (
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-electric-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {f}
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary w-full justify-center mb-4">Request a Quote</a>
          <a href="/size-guide/" class="btn-outline w-full justify-center text-sm">View Size Guide</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 prose-custom">
      <h2>Volleyball Training Shorts Built for Daily Use</h2>
      <p>Training shorts are the most-worn bottom garment in any volleyball player's kit. Unlike game shorts that are reserved for competition, training shorts endure daily practice sessions, conditioning workouts, and scrimmages throughout an entire season. The right pair needs to move freely through the explosive, multi-directional demands of volleyball while withstanding the washing frequency that daily athletic use requires.</p>
      <p>Our volleyball training shorts are part of a complete <a href="/practice-gear/">volleyball practice gear</a> collection designed for programs that take their training environment as seriously as game day.</p>

      <h2>Choosing the Right Inseam Length</h2>
      <p>Inseam preference in volleyball is strongly influenced by position, gender, and personal comfort. For women's volleyball programs, the 2" to 3" inseam is the standard competitive choice — it provides maximum range of motion during lateral defense, passing, and serving without restricting movement at any joint. For men's programs, 5" to 7" inseams are more common, providing slightly more coverage while remaining non-restrictive during vertical play.</p>
      <p>Mixed programs can accommodate different player preferences within a single order — specify the inseam length per player in your size roster submission.</p>

      <h2>Fabric Options for Training Shorts</h2>
      <p>Our standard training shorts use 100% lightweight polyester, which provides excellent moisture management and durability at an accessible price point. For players who prefer a compression-adjacent fit, our polyester-spandex blend option uses the same 88/12 ratio as our <a href="/volleyball-compression-shirts/">volleyball compression shirts</a> for consistent stretch properties across both garments.</p>

      <h2>Customization Options</h2>
      <p>Training shorts can be customized with team colors, side stripe designs, small logo placement, and optional player names or numbers. For programs ordering practice jerseys and shorts together, we coordinate the design across both pieces to create a cohesive practice uniform appearance. Use our <a href="/design-guide/">design guide</a> for artwork requirements.</p>

      <h2>Use Cases</h2>
      <ul>
        <li>Daily team practice and conditioning sessions</li>
        <li>Pre-season training camps and summer workouts</li>
        <li>Intra-squad scrimmages where game shorts are reserved</li>
        <li>Warm-up shorts worn under game shorts for pre-match preparation</li>
        <li>Weight room and agility training sessions</li>
      </ul>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <SpecsTable specs={specs} title="Volleyball Training Shorts Specifications" />
    </div>
  </section>

  <FAQSection faqs={faqs} title="Volleyball Training Shorts FAQs" />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-navy-950 mb-8">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map(p => <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />)}
      </div>
    </div>
  </section>

  <InlineQuoteSection productName={product.name} />


  <CTASection title="Equip Your Training Program" subtitle="Get a quote for custom volleyball training shorts in your team colors and preferred inseam lengths." />
</BaseLayout>
