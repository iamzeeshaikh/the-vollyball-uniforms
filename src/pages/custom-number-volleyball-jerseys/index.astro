---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

const product = products.find(p => p.slug === 'custom-number-volleyball-jerseys')!;
const related = products.filter(p => ['custom-name-volleyball-jerseys', 'personalized-volleyball-jerseys', 'blank-volleyball-jerseys'].includes(p.slug));

const specs = [
  { label: 'Primary Material', value: '100% Performance Polyester' },
  { label: 'Fabric Weight', value: '4.5 oz/yd² moisture-wicking interlock' },
  { label: 'Fit', value: 'Athletic cut (men\'s and women\'s)' },
  { label: 'Sizes Available', value: 'YXS – 4XL' },
  { label: 'Number Application', value: 'Full dye-sublimation — crack-proof, fade-resistant' },
  { label: 'Number Placement', value: 'Front chest and back (standard); back-only available' },
  { label: 'NFHS Number Height', value: 'Front minimum 4\", back minimum 6\"' },
  { label: 'NCAA Number Height', value: 'Front minimum 4\", back minimum 6\"' },
  { label: 'Care', value: 'Machine wash cool, tumble dry low' },
];

const faqs = [
  {
    question: 'What are the NFHS number size requirements for volleyball jerseys?',
    answer: 'Under NFHS rules, the number on the front of a volleyball jersey must be at least 4 inches tall, and the number on the back must be at least 6 inches tall. Numbers must contrast clearly with the jersey color. Our templates are pre-set to these minimums by default, and we offer larger sizes if your design benefits from bolder numbers.',
  },
  {
    question: 'How are single-digit and double-digit numbers handled differently?',
    answer: 'Single-digit numbers are centered on both the front and back panels. Double-digit numbers are treated as a unit — the two digits are spaced and sized together to meet the minimum height requirement as a pair. Our design software automatically adjusts the layout to ensure readability at both sizes without requiring manual adjustments from you.',
  },
  {
    question: 'What color contrast rules apply to jersey numbers?',
    answer: 'NFHS and NCAA both require that jersey numbers contrast clearly with the jersey background — meaning a light number on a dark jersey, or a dark number on a light jersey. Both governing bodies prohibit numbers that are the same color as the jersey body. Our design team applies a color contrast check to every mockup and will flag any combinations that don\'t meet standards before we go to print.',
  },
  {
    question: 'Is sublimation better than heat-transfer numbers for volleyball jerseys?',
    answer: 'Yes — for polyester volleyball jerseys, sublimation is significantly more durable. Heat-transfer numbers sit on top of the fabric and can crack or peel after repeated high-temperature washing and aggressive play. Sublimated numbers are bonded into the fabric at the molecular level, making them a permanent part of the jersey. They will not crack, peel, or fade regardless of how many times the jersey is washed.',
  },
  {
    question: 'Can I order a single jersey with a rush number for a player who joins mid-season?',
    answer: 'Yes. We accommodate single-jersey rush orders for mid-season roster additions. To maintain design consistency, we keep your original artwork on file for the entire season. Provide the player\'s size, number, and name (if applicable) and we\'ll produce a matching jersey. Rush singles typically ship within 7–10 business days of order confirmation.',
  },
  {
    question: 'Can I change player numbers between seasons without reordering everything?',
    answer: 'Because numbers are sublimated into the fabric, they cannot be altered after production. However, we retain your artwork template on file, so reordering for a new season with updated number assignments is fast — we simply update the roster and run a new proof. Many programs find this an efficient way to refresh their roster numbering annually.',
  },
  {
    question: 'Are any numbers prohibited in volleyball?',
    answer: 'Yes. Under NFHS rules, only numbers 1 through 99 are legal. Numbers 0 and 00 are not permitted under NFHS volleyball rules (unlike football or basketball). NCAA rules align similarly. We flag prohibited number assignments during the proofing stage so you can reassign before production begins.',
  },
  {
    question: 'Can you add numbers to blank jerseys I already have in stock?',
    answer: 'Sublimation cannot be applied to pre-made garments — it requires the fabric to be printed before cutting and sewing. If you have existing blank jerseys, the options are heat-transfer numbers (less durable) applied by a local decorator, or reordering fresh sublimated jerseys with numbers built in. We recommend the latter for long-term durability. See our <a href="/blank-volleyball-jerseys/">blank volleyball jerseys</a> page for teams that prefer to add numbers locally.',
  },  { question: 'Can two players on the same team share the same jersey number?', answer: 'No. NFHS and NCAA rules prohibit duplicate jersey numbers on the same team roster. When you submit your number roster, our system flags duplicates before production begins. We contact the program coordinator to resolve any number conflicts before the order moves to production so your team is always competition-compliant.' },
  { question: 'Can jersey numbers be combined with letters or position designations?', answer: 'Standard competition jerseys use numeric-only numbering as required by most governing bodies. However, letters can be incorporated as secondary design elements — for example, a small \'L\' indicator for the libero positioned below the number. This treatment does not conflict with number-only compliance requirements when designed correctly, and we confirm the approach against your specific governing body\'s rules before production.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Custom Number Volleyball Jerseys',
  description: 'Custom numbered volleyball jerseys with sublimated numbers that never crack or peel. NFHS and NCAA compliant sizing.',
  brand: { '@type': 'Brand', name: 'The Volleyball Uniforms' },
  url: `https://thevolleyballuniforms.com/${product.slug}/`,
  image: product.images.map(img => `https://thevolleyballuniforms.com${img}`),
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'USD',
    price: '18.00',
    priceValidUntil: '2027-12-31',
    url: `https://thevolleyballuniforms.com/${product.slug}/`,
    seller: { '@type': 'Organization', name: 'The Volleyball Uniforms', url: 'https://thevolleyballuniforms.com' },
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '97' , bestRating: '5', worstRating: '1' },
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Volleyball Jerseys', href: '/volleyball-jerseys/' },
  { label: 'Custom Number Volleyball Jerseys' },
];
import InlineQuoteSection from '../../components/InlineQuoteSection.astro';
---

<BaseLayout
  title="Custom Number Volleyball Jerseys — NFHS Compliant | The Volleyball Uniforms"
  description="Custom numbered volleyball jerseys with sublimated numbers that never crack or peel. NFHS and NCAA compliant sizing. Bulk orders welcome. Get a free quote today."
  schema={schema}
  canonical="https://thevolleyballuniforms.com/custom-number-volleyball-jerseys/"
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4"><Breadcrumbs items={breadcrumbs} /></div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <ProductGallery images={product.images} productName={product.name} />
        <div>
          <div class="text-sm text-electric-600 font-semibold mb-2">Volleyball Jerseys</div>
          <h1 class="text-4xl font-extrabold text-navy-950 mb-4 leading-tight">Custom Number Volleyball Jerseys</h1>
          <div class="flex items-center gap-2 mb-4">
            <div class="flex gap-0.5">{[1,2,3,4,5].map(() => <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}</div>
            <span class="text-sm text-gray-500">4.8 / 5 (97 reviews)</span>
          </div>
          <p class="text-gray-600 leading-relaxed mb-6">Numbers on a volleyball jersey do more than identify a player — they signal compliance, command recognition on the court, and hold up through a full competitive season without fading. Our custom number volleyball jerseys use dye-sublimation to permanently bond each number into the polyester fabric, meeting NFHS and NCAA size and contrast requirements from day one.</p>
          <div class="space-y-3 mb-8">
            {['Sublimated numbers (never crack or peel)', 'NFHS & NCAA compliant sizing', 'Front and back number placement', 'High color-contrast options', 'Single or double-digit configurations', 'Number + name combination available'].map(f => (
              <div class="flex items-center gap-3 text-sm text-gray-700">
                <svg class="w-5 h-5 text-electric-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {f}
              </div>
            ))}
          </div>
          <a href="/request-a-quote/" class="btn-primary w-full justify-center mb-4">Request a Quote</a>
          <a href="/size-guide/" class="btn-outline w-full justify-center text-sm">View Size Guide</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 prose-custom">
      <h2>NFHS and NCAA Number Size Requirements You Need to Know</h2>
      <p>Both NFHS and NCAA specify minimum number dimensions that affect every competitive volleyball program's jersey design. Under NFHS rules, the front number must be at least 4 inches tall and the back number must be at least 6 inches tall. NCAA requirements align: 4-inch front minimum, 6-inch back minimum. These measurements apply to the numeral height specifically — the total block including any outline or drop shadow does not count toward the minimum. Numbers must also contrast clearly with the jersey body color. Our default templates are pre-built to these minimums and include a contrast verification step in every mockup review. Programs competing under USAV, AAU, or international FIVB rules can request a compliance check against their specific governing body's current rulebook when submitting their order. See our <a href="/high-school-volleyball-uniforms/">high school volleyball uniforms</a> page for full NFHS compliance coverage.</p>

      <h2>Number Style Options: Block, Athletic, Collegiate, and Custom Fonts</h2>
      <p>Number font choice affects both aesthetics and readability. Block number fonts with consistent stroke widths and minimal ornamentation are the most legible from 30+ feet under variable gym lighting — they are the standard for NFHS and NCAA compliance contexts where scorekeepers and officials must read numbers quickly. Athletic number fonts add slight serif details or tapered strokes that give jerseys a professional sport aesthetic without sacrificing readability. Collegiate number styles feature heavier weight with pronounced serifs common in traditional university athletic programs. Custom number font designs — program-specific or artwork-matched styles — are available for programs that want a distinctive visual identity. All font options are available with sublimation at no additional cost per design element. Our designers send a number font reference sheet with every initial mockup.</p>

      <h2>Front-and-Back Numbering vs. Back-Only Configurations</h2>
      <p>NFHS and NCAA both require numbers on both the front and back of competition jerseys. Back-only numbering is permitted for some recreational leagues and lower-level club events where governing body rules are less strict. Front numbers are typically placed at the center chest and scaled to the 4-inch minimum (or larger, for programs that prefer a bolder front treatment). Back numbers sit at the upper-center back panel and are commonly produced at 6–8 inches for maximum visibility. For youth programs where YXS and YS jersey sizes cannot physically accommodate a 6-inch back number, we proportionally reduce the number to the largest size that fits the panel while still meeting compliance requirements for the jersey size in question.</p>

      <h2>Managing Number Assignment Across a Full Roster</h2>
      <p>NFHS and NCAA both prohibit duplicate jersey numbers on the same team roster. When you submit your number roster, our system flags any duplicate assignments before the order enters production — we contact the coordinator to resolve conflicts rather than proceeding with non-compliant numbers. NFHS additionally prohibits the numbers 0 and 00, which are legal in other sports but not in volleyball; we flag these as well. For programs building rosters from scratch, we recommend reserving specific number ranges for different roster roles (setters, liberos, serving specialists) to simplify future jersey reorders when individual players change positions or numbers. Our roster template includes a notes field where number assignment rationale can be recorded for future reference.</p>

      <h2>Number Color Contrast Requirements for High School Compliance</h2>
      <p>Color contrast between the jersey number and the jersey body is one of the most commonly flagged compliance issues in volleyball uniform review. NFHS requires numbers to clearly contrast with the background — light numbers on dark jerseys, dark numbers on light jerseys. The standard does not specify a numerical contrast ratio, but match officials have discretion to flag numbers they judge as insufficiently visible. Navy numbers on a royal blue jersey, dark gray numbers on black, and dark red numbers on maroon are all common examples of combinations that fail contrast review even when the colors are technically different. Our design team applies a contrast check to every number placement mockup and flags combinations that fall below visibility standards before any jersey enters production. For programs with strict color palettes, we discuss alternative number treatment options — such as a white border around a dark number on a dark background — to achieve both compliance and design consistency. Visit our <a href="/design-guide/">design guide</a> for artwork color specifications.</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <SpecsTable specs={specs} title="Custom Number Volleyball Jerseys Specifications" />
    </div>
  </section>

  <FAQSection faqs={faqs} title="Custom Number Volleyball Jerseys FAQs" />

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-extrabold text-navy-950 mb-8">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map(p => <ProductCard name={p.name} slug={p.slug} image={p.images[0]} description={p.shortDescription} />)}
      </div>
    </div>
  </section>

  <InlineQuoteSection productName={product.name} />


  <CTASection title="Get Compliant, Permanent Numbers on Every Jersey" subtitle="Free mockup with your number roster — bulk pricing for teams of all sizes." />
</BaseLayout>
