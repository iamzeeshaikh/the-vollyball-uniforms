---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead {...props} />
    <meta name="google-site-verification" content="hjG_MMZAmnmUecRepnjaPiUiS43xpZx8oFSXSZrzSNw" />
  </head>
  <body class="bg-white">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="https://chat.zeeops.dev/widget.js?siteId=volleyballuniforms"></script>
  </body>
</html>
