---
const testimonials = [
  {
    text: "The quality of our team's volleyball uniforms exceeded our expectations. The sublimation printing is vibrant and has held up through an entire season of weekly matches without any fading.",
    author: "Coach M. Torres",
    role: "High School Volleyball Coach",
    rating: 5,
  },
  {
    text: "We ordered custom jerseys for our 24-player college club team. The ordering process was simple, turnaround was fast, and every player got exactly the right fit.",
    author: "Athletic Director",
    role: "Division III College Program",
    rating: 5,
  },
  {
    text: "Our youth volleyball league needed affordable but professional-looking uniforms. The Volleyball Uniforms delivered exactly that — quality gear at a price that works for a nonprofit organization.",
    author: "League Coordinator",
    role: "Youth Volleyball League",
    rating: 5,
  },
  {
    text: "The custom warm-up suits we ordered for travel days look incredible. Every team member commented on the premium feel. We'll definitely be ordering again for next season.",
    author: "Head Coach",
    role: "Women's Club Volleyball Team",
    rating: 5,
  },
];
---

<section class="py-20 bg-navy-950">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-14">
      <h2 class="text-4xl font-extrabold text-white mb-4">What Teams Say About Us</h2>
      <p class="text-navy-400 text-lg max-w-2xl mx-auto">Trusted by volleyball programs across the United States — from youth leagues to college teams.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map(t => (
        <div class="bg-navy-900 rounded-2xl p-6 border border-navy-800 hover:border-gold-500/30 transition-colors">
          <div class="flex gap-1 mb-4">
            {[...Array(t.rating)].map(() => (
              <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-navy-300 text-sm leading-relaxed mb-5 italic">"{t.text}"</p>
          <div>
            <div class="text-white font-semibold text-sm">{t.author}</div>
            <div class="text-navy-500 text-xs mt-0.5">{t.role}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
