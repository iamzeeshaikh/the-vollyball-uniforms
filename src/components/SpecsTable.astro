---
interface Spec {
  label: string;
  value: string;
}

interface Props {
  specs: Spec[];
  title?: string;
}

const { specs, title = 'Product Specifications' } = Astro.props;
---

<div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-200">
  <div class="bg-navy-950 px-6 py-4">
    <h3 class="text-white font-bold text-lg">{title}</h3>
  </div>
  <table class="w-full text-sm">
    <tbody>
      {specs.map((spec, i) => (
        <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
          <td class="px-6 py-3 font-semibold text-gray-700 w-1/3">{spec.label}</td>
          <td class="px-6 py-3 text-gray-600">{spec.value}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
