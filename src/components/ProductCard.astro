---
interface Props {
  name: string;
  slug: string;
  image: string;
  description: string;
  category?: string;
}

const { name, slug, image, description, category } = Astro.props;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
  <a href={`/${slug}/`} class="block">
    <div class="relative overflow-hidden aspect-[4/3] bg-gray-50">
      <img
        src={image}
        alt={`${name} - Custom volleyball uniforms by The Volleyball Uniforms`}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        width="400"
        height="300"
      />
      {category && (
        <span class="absolute top-3 left-3 bg-navy-950/80 text-white text-xs font-semibold px-3 py-1 rounded-full backdrop-blur-sm">
          {category}
        </span>
      )}
    </div>
    <div class="p-5">
      <h3 class="font-bold text-navy-950 text-lg mb-2 group-hover:text-electric-600 transition-colors">{name}</h3>
      <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-2">{description}</p>
      <div class="flex items-center justify-between">
        <span class="text-electric-600 font-semibold text-sm flex items-center gap-1.5">
          Get a Quote
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
        <div class="flex items-center gap-1">
          {[1,2,3,4,5].map(() => <svg class="w-3.5 h-3.5 text-gold-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
        </div>
      </div>
    </div>
  </a>
</article>
